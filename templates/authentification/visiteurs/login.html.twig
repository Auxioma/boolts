{% extends 'base.html.twig' %}

{% block title %}Accueil{% endblock %}

{% block body %}
<header class="topbar position-relative">
    <div class="container-fluid g-0">
        <nav class="navbar navbar-expand-lg topbar-nav">

            <a class="navbar-brand topbar-brand" href="#">
                <img src="{{ asset('images/logo/logo-blanc.svg') }}" alt="Boolts" class="topbar-logo">
            </a>

            <div class="topbar-mobile-actions d-flex align-items-center ms-auto">
                <a href="#" class="topbar-avatar-link">
                    <img src="{{ asset('images/authentification/auxioma.png') }}" alt="Profil utilisateur" class="topbar-avatar">
                </a>

                <button
                    class="navbar-toggler topbar-toggler"
                    type="button"

                    {# data-bs-toggle="collapse"
                    data-bs-target="#mainNavbar" #}
                    aria-controls="mainNavbar"
                    aria-expanded="false"
                    aria-label="Ouvrir le menu"
                >
                    <span class="navbar-toggler-icon"></span>
                </button>
            </div>

            <div class="collapse navbar-collapse" id="mainNavbar">
                <ul class="navbar-nav ms-lg-auto align-items-lg-center topbar-menu">
                    <li class="nav-item">
                        <a class="nav-link" href="#">Acheter</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#">Louer</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#">Vendre</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#">Trouver un pro</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#">Exclusivités</a>
                    </li>

                    <li class="nav-item ms-lg-3">
                        <a href="#" class="btn topbar-btn">
                            <span class="topbar-btn-icon">+</span>
                            Déposer une annonce
                        </a>
                    </li>

                    <li class="nav-item ms-lg-3 d-none d-lg-block">
                        <a href="#" class="topbar-avatar-link">
                            <img src="{{ asset('images/authentification/auxioma.png') }}" alt="Profil utilisateur" class="topbar-avatar">
                        </a>
                    </li>
                </ul>
            </div>

        </nav>
    </div>
</header>
    {#
<nav id="mobile-menu">
    <ul>
        <li><a href="#">Acheter</a></li>
        <li><a href="#">Louer</a></li>
        <li><a href="#">Vendre</a></li>
        <li><a href="#">Trouver un pro</a></li>
        <li><a href="#">Exclusivités</a></li>
        <li><a href="#">Déposer une annonce</a></li>
    </ul>
</nav>
    #}
    <main>
        <div class="container-fluid">
            <div class="row">
                <div class="col-12 col-lg-6">
                    <div class="row">
                        <div class="col-12">
                            <div class="row">
                                <div class="col-md-11 col-lg-8 mx-auto">
                                    <div class="login my-48">
                                        <h1 class="mb-0">Connexion</h1>
                                        <div class="media-social mt-32">
                                            <a href="" class="btn-bg-noir d-block w-100 text-center">Connexion via Apple</a>
                                            <a href="" class="btn-bg-border-gris mt-16 d-block w-100 text-center">Connexion via Google</a>
                                        </div>
                                        <div class="divider my-32">
                                            <span>OU</span>
                                        </div>
                                        <div class="formulaire">
                                            <form method="post">
                                                <div class="">
                                                    <label for="email" class="form-label mb-16">Adresse e-mail</label>
                                                    <input type="email" value="{{ last_username }}" name="email" id="inputEmail" class="form-control mb-16 {% if error %}flash-input-error{% endif %}" autocomplete="email" required autofocus>

                                                    <label for="pwd" class="form-label mb-16">Mot de passe</label>
                                                    <input type="password" name="password" id="inputPassword" class="form-control {% if error %}flash-input-error{% endif %}" autocomplete="current-password" required>

                                                    <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

                                                    {# message flash #}
                                                    {% for label, messages in app.flashes %}
                                                        {% if label in ['danger', 'error', 'warning', 'success'] %}
                                                            {% for message in messages %}
                                                                <span class="
                                                        flash-message mt-24 d-block
                                                        {% if label in ['danger', 'error'] %}flash-message-error{% endif %}
                                                        {% if label == 'warning' %}flash-message-error{% endif %}
                                                        {% if label == 'error' %}flash-message-error{% endif %}
                                                        {% if label == 'success' %}flash-message-success{% endif %}
                                                    ">
                                                        {{ message }}
                                                    </span>
                                                            {% endfor %}
                                                        {% endif %}
                                                    {% endfor %}

                                                    {% if error %}
                                                        <div class="flash-message flash-message-error mt-24 d-block">
                                                            {{ error.messageKey|trans(error.messageData, 'security') }}
                                                        </div>
                                                    {% endif %}

                                                    <button class="mt-32 btn-submit w-100 text-white" type="submit">Se connecter</button>
                                                </div>
                                            </form>
                                        </div>
                                        <a href="{{ path('app_forgot_password_request') }}" class="my-24 d-block w-100 text-center text-blue link-blue">Mot de passe oublié ?</a>

                                        <a href="{{ path('app_visiteur_inscription') }}" class="btn-bg-border-blue d-block w-100 text-center">
                                            Inscription
                                        </a>

                                        <a href="{{ path('app_professionnelle_connexion') }}" class="mt-34 d-block w-100 text-center text-blue link-blue">
                                            Vous êtes un professionnel ?
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-6 d-none d-lg-block pe-0">
                    <div class="bg-login"></div>
                </div>
            </div>

        </div>
    </main>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/mmenu-js@9/dist/mmenu.css">
<script src="https://cdn.jsdelivr.net/npm/mmenu-js@9/dist/mmenu.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function () {
    const menu = new Mmenu('#mobile-menu', {
        navbar: {
            title: 'Menu'
        },
        offCanvas: {
            position: 'right-front'
        }
    });

    const api = menu.API;
    const btn = document.querySelector('.topbar-toggler');

    if (btn) {
        btn.addEventListener('click', function (e) {
            e.preventDefault();
            e.stopPropagation();
            api.open();
        });
    }
});
</script>

{% endblock %}
