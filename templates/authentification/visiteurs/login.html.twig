{% extends 'base.html.twig' %}

{% block title %}Accueil{% endblock %}

{% block body %}
    <main>
        <div class="container-fluid">
            <div class="row">
                <div class="col-12 col-lg-6">
                    <div class="row">
                        <div class="col-12">
                            <div class="row">
                                <div class="col-md-11 col-lg-8 mx-auto">
                                    <div class="login my-48">
                                        <h1 class="mb-0">Connexion</h1>
                                        <div class="media-social mt-32">
                                            <a href="" class="btn-bg-noir d-block w-100 text-center">Connexion via Apple</a>
                                            <a href="" class="btn-bg-border-gris mt-16 d-block w-100 text-center">Connexion via Google</a>
                                        </div>
                                        <div class="divider my-32">
                                            <span>OU</span>
                                        </div>
                                        <div class="formulaire">
                                            <form method="post">
                                                <div class="">
                                                    <label for="email" class="form-label mb-16">Adresse e-mail</label>
                                                    <input type="email" value="{{ last_username }}" name="email" id="inputEmail" class="form-control mb-16 {% if error %}flash-input-error{% endif %}" autocomplete="email" required autofocus>

                                                    <label for="pwd" class="form-label mb-16">Mot de passe</label>
                                                    <input type="password" name="password" id="inputPassword" class="form-control {% if error %}flash-input-error{% endif %}" autocomplete="current-password" required>

                                                    <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

                                                    {# message flash #}
                                                    {% for label, messages in app.flashes %}
                                                        {% if label in ['danger', 'error', 'warning', 'success'] %}
                                                            {% for message in messages %}
                                                                <span class="
                                                        flash-message mt-24 d-block
                                                        {% if label in ['danger', 'error'] %}flash-message-error{% endif %}
                                                        {% if label == 'warning' %}flash-message-error{% endif %}
                                                        {% if label == 'error' %}flash-message-error{% endif %}
                                                        {% if label == 'success' %}flash-message-success{% endif %}
                                                    ">
                                                        {{ message }}
                                                    </span>
                                                            {% endfor %}
                                                        {% endif %}
                                                    {% endfor %}

                                                    {% if error %}
                                                        <div class="flash-message flash-message-error mt-24 d-block">
                                                            {{ error.messageKey|trans(error.messageData, 'security') }}
                                                        </div>
                                                    {% endif %}

                                                    <button class="mt-32 btn-submit w-100 text-white" type="submit">Se connecter</button>
                                                </div>
                                            </form>
                                        </div>
                                        <a href="{{ path('app_forgot_password_request') }}" class="my-24 d-block w-100 text-center text-blue link-blue">Mot de passe oublié ?</a>

                                        <a href="{{ path('app_visiteur_inscription') }}" class="btn-bg-border-blue d-block w-100 text-center">
                                            Inscription
                                        </a>

                                        <a href="{{ path('app_professionnelle_connexion') }}" class="mt-34 d-block w-100 text-center text-blue link-blue">
                                            Vous êtes un professionnel ?
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-6 d-none d-lg-block pe-0">
                    <div class="bg-login"></div>
                </div>
            </div>

        </div>
    </main>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/mmenu-js@9/dist/mmenu.css">
<script src="https://cdn.jsdelivr.net/npm/mmenu-js@9/dist/mmenu.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function () {
    const menu = new Mmenu('#mobile-menu', {
        navbar: {
            title: 'Menu'
        },
        offCanvas: {
            position: 'right-front'
        }
    });

    const api = menu.API;
    const btn = document.querySelector('.topbar-toggler');

    if (btn) {
        btn.addEventListener('click', function (e) {
            e.preventDefault();
            e.stopPropagation();
            api.open();
        });
    }
});
</script>

{% endblock %}
