{% extends 'base.html.twig' %}

{% block title %}{{ 'visiteur.reset_password.reset.meta.title'|trans }}{% endblock %}

{% block body %}
    <main>
        <div class="container-fluid">
            <div class="row">
                <div class="col-12 col-lg-6">
                    <div class="row">
                        <div class="col-12">
                            <div class="row">
                                <div class="col-md-11 col-lg-8 mx-auto">
                                    <div class="login my-48">

                                        <h1 class="mb-0">
                                            {{ 'visiteur.reset_password.reset.title'|trans }}
                                        </h1>

                                        <div class="formulaire mt-32">

                                            {{ form_start(resetForm, {
                                                attr: {
                                                    'data-turbo': 'false'
                                                }
                                            }) }}

                                            <div>

                                                <label for="reset_form_plainPassword_first" class="form-label mb-16">
                                                    {{ 'visiteur.reset_password.reset.password.label'|trans }}
                                                </label>

                                                {{ form_widget(resetForm.plainPassword.first, {
                                                    attr: {
                                                        class: 'form-control mb-16',
                                                        placeholder: 'visiteur.reset_password.reset.password.placeholder'|trans
                                                    }
                                                }) }}

                                                <label for="reset_form_plainPassword_second" class="form-label mb-16">
                                                    {{ 'visiteur.reset_password.reset.password_confirm.label'|trans }}
                                                </label>

                                                {{ form_widget(resetForm.plainPassword.second, {
                                                    attr: {
                                                        class: 'form-control mb-16',
                                                        placeholder: 'visiteur.reset_password.reset.password_confirm.placeholder'|trans
                                                    }
                                                }) }}

                                                {% for label, messages in app.flashes %}
                                                    {% if label in ['danger', 'error', 'warning'] %}
                                                        {% for message in messages %}
                                                            <span class="flash-message flash-message-error mt-24 d-block">
                                                            {{ message|trans }}
                                                        </span>
                                                        {% endfor %}
                                                    {% endif %}
                                                {% endfor %}

                                                <button class="mt-32 btn-submit w-100 text-white" type="submit">
                                                    {{ 'visiteur.reset_password.reset.submit'|trans }}
                                                </button>

                                            </div>

                                            {{ form_end(resetForm) }}

                                        </div>

                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>


                <div class="col-lg-6 d-none d-lg-block pe-0">
                    <div class="bg-login"></div>
                </div>

            </div>
        </div>
    </main>
{% endblock %}
