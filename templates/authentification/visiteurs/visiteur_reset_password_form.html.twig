{% extends 'base.html.twig' %}

{% block title %}Accueil{% endblock %}

{% block body %}
    <main>
        <div class="container-fluid">
            <div class="row">
                <div class="col-12 col-lg-6">
                    <div class="row">
                        <div class="col-12">
                            <div class="row">
                                <div class="col-md-11 col-lg-8 mx-auto">
                                    <div class="login my-48">
                                        <h1 class="mb-0">Modifiez votre mot de passe</h1>
                                        <div class="formulaire mt-32">
                                            {{ form_start(resetForm, {
                                                attr: {
                                                    'data-turbo': 'false'
                                                }
                                            }) }}
                                                <div class="">
                                                    <label for="email" class="form-label mb-16">Mot de passe</label>
                                                    {{ form_widget(resetForm.plainPassword.first, {
                                                        attr: {
                                                            class: 'form-control mb-16',
                                                            placeholder: 'Nouveau mot de passe'
                                                        }
                                                    }) }}


                                                    <label for="pwd" class="form-label mb-16">Confirmez votre mot de passe</label>
                                                    {{ form_widget(resetForm.plainPassword.second, {
                                                        attr: {
                                                            class: 'form-control mb-16',
                                                            placeholder: 'Confirmer le mot de passe'
                                                        }
                                                    }) }}

                                                    <button class="mt-32 btn-submit w-100 text-white" type="submit">Se connecter</button>
                                                </div>
                                            {{ form_end(resetForm) }}
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-6 d-none d-lg-block pe-0">
                    <div class="bg-login"></div>
                </div>
            </div>

        </div>
    </main>

{% endblock %}
