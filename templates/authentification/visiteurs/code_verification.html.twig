{% extends 'base.html.twig' %}

{% block title %}{{ 'visiteur.register.verify_code.meta.title'|trans }}{% endblock %}

{% block body %}
    <main>
        <div class="container-fluid">
            <div class="row">
                <div class="col-12 col-lg-6">
                    <div class="row">
                        <div class="col-md-11 col-lg-8 mx-auto">
                            <div class="login my-48">
                                <h1 class="mb-0">
                                    {{ 'visiteur.register.verify_code.title'|trans }}
                                </h1>

                                <div class="opt-code-recu-mail mt-32">
                                    <div class="formulaire">
                                        {{ form_start(codeForm, {
                                            attr: stimulus_controller('otp')|merge(
                                                stimulus_action('otp', 'submit', 'submit')
                                            )|merge({
                                                novalidate: 'novalidate',
                                                id: 'otp-form',
                                                'data-turbo': 'false'
                                            })
                                        }) }}

                                        {{ form_widget(codeForm.code, {
                                            attr: stimulus_target('otp', 'hiddenInput')|merge({
                                                class: 'otp-hidden-input',
                                                autocomplete: 'one-time-code',
                                                inputmode: 'numeric'
                                            })
                                        }) }}

                                        <div class="otp-container-recu-par-mail" id="otp-container-recu-par-mail">
                                            {% for i in 1..6 %}
                                                <input
                                                    class="otp-input-recu-par-mail{% if not loop.last %} mr-14{% endif %}"
                                                    type="text"
                                                    maxlength="1"
                                                    inputmode="numeric"
                                                    pattern="[0-9]*"
                                                    autocomplete="{{ loop.first ? 'one-time-code' : 'off' }}"
                                                    aria-label="{{ 'visiteur.register.verify_code.digit_label'|trans({'%position%': i}) }}"
                                                    {{ stimulus_target('otp', 'digit') }}
                                                    {{ stimulus_action('otp', 'input', 'input') }}
                                                    {{ stimulus_action('otp', 'keydown', 'keydown') }}
                                                    {{ stimulus_action('otp', 'paste', 'paste') }}
                                                >
                                            {% endfor %}
                                        </div>

                                        {% for label, messages in app.flashes %}
                                            {% if label in ['danger', 'error', 'warning'] %}
                                                {% for message in messages %}
                                                    <span class="flash-message flash-message-error mt-24 d-block">
                                                        {{ message|trans }}
                                                    </span>
                                                {% endfor %}
                                            {% endif %}
                                        {% endfor %}

                                        {% if codeForm.vars.errors|length > 0 %}
                                            {% for error in codeForm.vars.errors %}
                                                <div class="flash-message flash-message-error mt-24 d-block">
                                                    {{ error.message|trans }}
                                                </div>
                                            {% endfor %}
                                        {% endif %}

                                        <button class="mt-32 btn-submit w-100 text-white" type="submit">
                                            {{ 'visiteur.register.verify_code.submit'|trans }}
                                        </button>

                                        {{ form_end(codeForm) }}
                                    </div>
                                </div>

                                <div class="divider my-32">
                                    <span>{{ 'visiteur.register.verify_code.or'|trans }}</span>
                                </div>

                                <form method="post" action="{{ path('app_auth_resend_code') }}">
                                    <button type="submit" class="btn-bg-border-blue d-block w-100 text-center">
                                        {{ 'visiteur.register.verify_code.resend_code'|trans }}
                                    </button>
                                </form>

                                <a href="{{ path('app_visiteur_inscription') }}" class="mt-34 d-block w-100 text-center text-blue link-blue">
                                    {{ 'visiteur.register.verify_code.change_email'|trans }}
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-6 d-none d-lg-block pe-0 adaptation-image-login">
                    <div class="bg-login"></div>
                </div>
            </div>
        </div>
    </main>
{% endblock %}
