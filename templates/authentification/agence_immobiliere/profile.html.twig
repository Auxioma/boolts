{% extends 'base.html.twig' %}

{% block title %}Accueil{% endblock %}

{% block body %}
     <main>
        <div class="container-fluid">
            <div class="row">
                <div class="col-12">
                    <div class="row">
                        <div class="col-12">
                            <div class="row">
                                <div class="col-md-11 col-md-10 col-lg-4 mx-auto ">
                                    <div class="login my-48 px-48 py-48 bg-white rounded-24">
                                        <h1 class="mb-0 text-center">Inscrivez-votre agence dès maintenant</h1>
                                        <div class="formulaire mt-32">
                                            {{ form_start(form) }}
                                            <div class="">
                                                <label for="email" class="form-label mb-16">Nom*</label>
                                                {{ form_widget(form.nom) }}

                                                <label for="pwd" class="form-label mb-16">Prénom*</label>
                                                {{ form_widget(form.prenom) }}

                                                <label for="pwd" class="form-label mb-16">Mot de passe*</label>
                                                {{ form_widget(form.plainPassword.first) }}

                                                <label for="pwd" class="form-label mb-16">Confirmer le mot de passe*</label>
                                                {{ form_widget(form.plainPassword.second) }}
                                                <div class="form-check-therms mb-32">
                                                    <label class="form-check-label" for="terms">
                                                        {{ form_widget(form.agreeTerms) }}
                                                        ’accepte les conditions d’utilisation de Boolts.*
                                                    </label>
                                                </div>
                                                {# message flash #}
                                                {% for label, messages in app.flashes %}
                                                    {% if label in ['danger', 'error', 'warning'] %}
                                                        {% for message in messages %}
                                                            <span class="
                                                                    flash-message mt-32 d-block
                                                                    {% if label in ['danger', 'error'] %}flash-message-error{% endif %}
                                                                    {% if label == 'warning' %}flash-message-error{% endif %}
                                                                ">
                                                                    {{ message }}
                                                                </span>
                                                        {% endfor %}
                                                    {% endif %}
                                                {% endfor %}
                                                <button class=" btn-submit w-100 text-white" type="submit">Se connecter</button>
                                            </div>
                                            {{ form_end(form) }}
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
{% endblock %}
{% block stylesheets %}
    <style>
        body {
            background: url("{{ asset('images/authentification/real-estate.webp') }}") no-repeat center center fixed;
            background-size: cover;
            min-height: 100vh;
        }
    </style>
{% endblock %}
