{% extends 'base.html.twig' %}

{% block title %}Accueil
{% endblock %}

{% block body %}
    <header class="topbar position-relative">
        <div class="container-fluid g-0">
            <nav class="navbar navbar-expand-lg topbar-nav">

                <a class="navbar-brand topbar-brand" href="#">
                    <img src="{{ asset('images/logo/logo-blanc.svg') }}" alt="Boolts" class="topbar-logo">
                </a>

                <div class="topbar-mobile-actions d-flex align-items-center ms-auto">
                    <a href="#" class="topbar-avatar-link">
                        <img src="{{ asset('images/authentification/auxioma.png') }}" alt="Profil utilisateur" class="topbar-avatar">
                    </a>

                    <button class="navbar-toggler topbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar" aria-controls="mainNavbar" aria-expanded="false" aria-label="Ouvrir le menu">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                </div>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav ms-lg-auto align-items-lg-center topbar-menu">
                        <li class="nav-item">
                            <a class="nav-link" href="#">Acheter</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#">Louer</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#">Vendre</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#">Trouver un pro</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#">Exclusivités</a>
                        </li>

                        <li class="nav-item ms-lg-3">
                            <a href="#" class="btn topbar-btn">
                                <span class="topbar-btn-icon">+</span>
                                Déposer une annonce
                            </a>
                        </li>

                        <li class="nav-item ms-lg-3 d-none d-lg-block">
                            <a href="#" class="topbar-avatar-link">
                                <img src="{{ asset('images/authentification/auxioma.png') }}" alt="Profil utilisateur" class="topbar-avatar">
                            </a>
                        </li>
                    </ul>
                </div>

            </nav>
        </div>
    </header>

    <main>
        <div class="container-fluid">
            <div class="row">
                <div class="col-12">
                    <div class="row">
                        <div class="col-12">
                            <div class="row">
                                <div class="col-md-11 col-md-10 col-lg-4 mx-auto ">
                                    <div class="login my-48 px-48 py-48 bg-white rounded-24">
                                        <h1 class="mb-0">Vous avez reçu un code de validation par mail</h1>
                                        <div class="opt-code-recu-mail mt-32">
                                            <div class="formulaire">
                                                <form action="#">
                                                    <div class="">
                                                        <div class="otp-container-recu-par-mail" id="otp-container-recu-par-mail">
                                                            <input class="otp-input-recu-par-mail mr-14" type="text" maxlength="1" inputmode="numeric" pattern="[0-9]*" autocomplete="one-time-code">
                                                            <input class="otp-input-recu-par-mail mr-14" type="text" maxlength="1" inputmode="numeric" pattern="[0-9]*">
                                                            <input class="otp-input-recu-par-mail mr-14" type="text" maxlength="1" inputmode="numeric" pattern="[0-9]*">
                                                            <input class="otp-input-recu-par-mail mr-14" type="text" maxlength="1" inputmode="numeric" pattern="[0-9]*">
                                                            <input class="otp-input-recu-par-mail mr-14" type="text" maxlength="1" inputmode="numeric" pattern="[0-9]*">
                                                            <input class="otp-input-recu-par-mail" type="text" maxlength="1" inputmode="numeric" pattern="[0-9]*">
                                                        </div>
                                                        {# message flash #}
                                                        <span class="flash-message-error mt-24 d-block">Adresse e-mail ou mot de passe incorrect</span>

                                                        <button class="mt-32 btn-submit w-100 text-white" type="submit">Se connecter</button>
                                                    </div>
                                                </form>
                                            </div>

                                        </div>
                                        <div class="divider my-32">
                                            <span>OU</span>
                                        </div>

                                        <buttom type="submit" class="btn-bg-border-blue d-block w-100 text-center">
                                            Renvoyer le code
                                        </buttom>
                                        <a href="" class="mt-34 d-block w-100 text-center text-blue link-blue">
                                            Changer d’adresse mail
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-lg-6 d-none d-lg-block pe-0 adaptation-image-login">
                    <div class="bg-login"></div>
                </div>
            </div>
        </div>
    </main>
{% endblock %}
{% block stylesheets %}
    <style>
        body {
            background: url("{{ asset('images/authentification/immobilier.png') }}") no-repeat center center fixed;
            background-size: cover;
            min-height: 100vh;
        }
    </style>
{% endblock %}
