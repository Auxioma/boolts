{% extends 'base.html.twig' %}

{% block title %}Accueil
{% endblock %}

{% block body %}
    <main>
        <div class="container-fluid">
            <div class="row">
                <div class="col-12">
                    <div class="row">
                        <div class="col-12">
                            <div class="row">
                                <div class="col-md-11 col-md-10 col-lg-4 mx-auto ">
                                    <div class="login my-48 px-48 py-48 bg-white rounded-24">
                                        <h1 class="mb-0 text-center">Vous avez reçu un code de validation par mail</h1>
                                        <div class="opt-code-recu-mail mt-32">
                                            <div class="formulaire">
                                                {{ form_start(codeForm, {
                                                    attr: stimulus_controller('otp')|merge(
                                                        stimulus_action('otp', 'submit', 'submit')
                                                    )|merge({
                                                        novalidate: 'novalidate',
                                                        id: 'otp-form',
                                                        'data-turbo': 'false'
                                                    })
                                                }) }}

                                                {{ form_widget(codeForm.code, {
                                                    attr: stimulus_target('otp', 'hiddenInput')|merge({
                                                        class: 'otp-hidden-input',
                                                        autocomplete: 'one-time-code',
                                                        inputmode: 'numeric'
                                                    })
                                                }) }}

                                                    <div class="">
                                                        <div class="otp-container-recu-par-mail" id="otp-container-recu-par-mail">
                                                            {% for i in 1..6 %}
                                                                <input
                                                                    class="otp-input-recu-par-mail{% if not loop.last %} mr-14{% endif %}"
                                                                    type="text"
                                                                    maxlength="1"
                                                                    inputmode="numeric"
                                                                    pattern="[0-9]*"
                                                                    autocomplete="{{ loop.first ? 'one-time-code' : 'off' }}"
                                                                    {{ stimulus_target('otp', 'digit') }}
                                                                    {{ stimulus_action('otp', 'input', 'input') }}
                                                                    {{ stimulus_action('otp', 'keydown', 'keydown') }}
                                                                    {{ stimulus_action('otp', 'paste', 'paste') }}
                                                                >
                                                            {% endfor %}
                                                        </div>
                                                        {# message flash #}
                                                        {% for label, messages in app.flashes %}
                                                            {% if label in ['danger', 'error', 'warning', 'success'] %}
                                                                {% for message in messages %}
                                                                    <span class="
                                                        flash-message mt-24 d-block
                                                        {% if label in ['danger', 'error'] %}flash-message-error{% endif %}
                                                        {% if label == 'warning' %}flash-message-error{% endif %}
                                                        {% if label == 'error' %}flash-message-error{% endif %}
                                                        {% if label == 'success' %}flash-message-success{% endif %}
                                                    ">
                                                        {{ message }}
                                                    </span>
                                                                {% endfor %}
                                                            {% endif %}
                                                        {% endfor %}

                                                        {% form_theme codeForm _self %}

                                                        {% if codeForm.vars.errors|length > 0 %}
                                                            {% for error in codeForm.vars.errors %}
                                                                <div class="flash-message flash-message-error mt-24 d-block">
                                                                    {{ error.message }}
                                                                </div>
                                                            {% endfor %}
                                                        {% endif %}

                                                        <button class="mt-32 btn-submit w-100 text-white" type="submit">Se connecter</button>
                                                    </div>

                                                {{ form_end(codeForm) }}

                                            </div>

                                        </div>
                                        <div class="divider my-32">
                                            <span>OU</span>
                                        </div>

                                        <buttom type="submit" class="btn-bg-border-blue d-block w-100 text-center">
                                            Renvoyer le code
                                        </buttom>
                                        <a href="" class="mt-34 d-block w-100 text-center text-blue link-blue">
                                            Changer d’adresse mail
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
{% endblock %}
{% block stylesheets %}
    <style>
        body {
            background: url("{{ asset('images/authentification/real-estate.webp') }}") no-repeat center center fixed;
            background-size: cover;
            min-height: 100vh;
        }
    </style>
{% endblock %}
