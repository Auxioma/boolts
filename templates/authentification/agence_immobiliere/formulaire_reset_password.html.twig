{% extends 'base.html.twig' %}

{% block title %}Accueil{% endblock %}

{% block body %}
    <main>
        <div class="container-fluid">
            <div class="row">
                <div class="col-12">
                    <div class="row">
                        <div class="col-12">
                            <div class="row">
                                <div class="col-md-11 col-md-10 col-lg-4 mx-auto ">
                                    <div class="login my-48 px-48 py-48 bg-white rounded-24">
                                        <h1 class="mb-0 text-center">Modifiez votre mot de passe</h1>
                                        <div class="formulaire mt-32">
                                            {{ form_start(resetForm, {
                                                attr: {
                                                    'data-turbo': 'false'
                                                }
                                            }) }}
                                            <div class="">

                                                {% set errorMpd = resetForm.plainPassword.first.vars.errors|length > 0 %}

                                                <label for="email" class="form-label mb-16">Mot de passe</label>
                                                {{ form_widget(resetForm.plainPassword.first, {
                                                    attr: {
                                                        class: 'form-control mb-16 ' ~ (errorMpd ? 'flash-input-error' : ''),
                                                        placeholder: 'Nouveau mot de passe'
                                                    }
                                                }) }}


                                                <label for="pwd" class="form-label mb-16">Confirmez votre mot de passe</label>
                                                {{ form_widget(resetForm.plainPassword.second, {
                                                    attr: {
                                                        class: 'form-control mb-16 ' ~ (errorMpd ? 'flash-input-error' : ''),
                                                        placeholder: 'Confirmer le mot de passe'
                                                    }
                                                }) }}


                                                {# message flash #}
                                                {% for label, messages in app.flashes %}
                                                    {% if label in ['danger', 'error', 'warning', 'success'] %}
                                                        {% for message in messages %}
                                                            <span class="
                                                        flash-message mt-24 d-block
                                                        {% if label in ['danger', 'error'] %}flash-message-error{% endif %}
                                                        {% if label == 'warning' %}flash-message-error{% endif %}
                                                        {% if label == 'error' %}flash-message-error{% endif %}
                                                        {% if label == 'success' %}flash-message-success{% endif %}
                                                    ">
                                                        {{ message }}
                                                    </span>
                                                        {% endfor %}
                                                    {% endif %}
                                                {% endfor %}


                                                {% if resetForm.plainPassword.first.vars.errors|length > 0 %}
                                                    {% for error in resetForm.plainPassword.first.vars.errors %}
                                                        <div class="flash-message flash-message-error mt-24 d-block">
                                                            {{ error.message }}
                                                        </div>
                                                    {% endfor %}
                                                {% endif %}

                                                <button class="mt-32 btn-submit w-100 text-white" type="submit" data-turbo="false">Se connecter</button>
                                            </div>

                                            {{ form_end(resetForm) }}

                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

{% endblock %}
{% block stylesheets %}
    <style>
        body {
            background: url("{{ asset('images/authentification/real-estate.webp') }}") no-repeat center center fixed;
            background-size: cover;
            min-height: 100vh;
        }
    </style>
{% endblock %}
