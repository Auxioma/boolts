{% apply inline_css(source('email/authentification/confirmation_inscription/visiteurs.css')) %}
<!DOCTYPE html>
<html lang="{{ app.request.locale|default('fr') }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0"> 
    <title>Bienvenue sur Boolts</title>
</head>
<body>
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="mail-wrapper">
    <tr>
        <td align="center">
            <table role="presentation" width="600" cellpadding="0" cellspacing="0" border="0" class="mail-container">

                <tr>
                    <td class="mail-header">
                        <table role="presentation" cellpadding="0" cellspacing="0" border="0" class="brand-table">
                            <tr>
                                <td valign="middle">
                                    <img
                                        src="{{ absolute_url(asset('images/logo/mail.svg')) }}"
                                        alt="Boolts"
                                        class="brand-logo"
                                        width="134"
                                    >
                                </td>
                            </tr>
                        </table>
                    </td>
                </tr>

                <tr>
                    <td class="mail-main">
                        <h1 class="mail-title">
                            Bonjour, vous êtes bien inscrit sur
                            <span class="mail-title-accent">boolts.com</span> !
                        </h1>

                        <table role="presentation" cellpadding="0" cellspacing="0" border="0" class="button-wrapper">
                            <tr>
                                <td>
                                    <a href="{{ url('app_dashboard_agence_immobiliere_dashboard') }}" class="primary-button">
                                        Découvrir mon dashboard
                                    </a>
                                </td>
                            </tr>
                        </table>

                        <p class="intro-text">
                            Lorem ipsum dolor sit amet
                        </p>
                    </td>
                </tr>

                <tr>
                    <td class="footer-top">
                        <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                            <tr>
                                <td class="footer-column" valign="top">
                                    <p class="footer-brand">boolts</p>
                                    <div class="footer-address">
                                        <p>©{{ "now"|date("Y") }} Boolts</p>
                                    </div>
                                </td>

                                <td class="footer-column-right" valign="top">
                                    <div class="social-icons">
                                                <a href="{{ instagramUrl|default('#') }}">
                                                    <img
                                                        src="{{ absolute_url(asset('images/logo/instagram.svg')) }}"
                                                        alt="Instagram"
                                                        width="20"
                                                        height="20"
                                                    >
                                                </a>
                                                <a href="{{ facebookUrl|default('#') }}">
                                                    <img
                                                        src="{{ absolute_url(asset('images/logo/facebook.svg')) }}"
                                                        alt="Facebook"
                                                        width="20"
                                                        height="20"
                                                    >
                                                </a>
                                    </div>

                                    <div class="footer-links">
                                        <p>
                                            <a href="{{ cguUrl|default('#') }}" target="_blank" rel="noopener">CGU</a>
                                        </p>
                                        <p>
                                            <a href="{{ contactUrl|default('#') }}" target="_blank" rel="noopener">Nous contacter</a>
                                        </p>
                                    </div>
                                </td>
                            </tr>
                        </table>
                    </td>
                </tr>

                <tr>
                    <td class="footer-legal">
                        <p>
                            Boolts is a registered trademark. Instagram and Facebook are trademarks of Meta Inc., registered in the U.S. and other countries.
                            <br>
                            Vous avez reçu ce message parce que vous vous êtes inscrit sur notre site le {{ "now"|date("d/m/Y") }}.
                        </p>
                        <p>
                            Vous ne souhaitez plus recevoir d’e-mail de notre part ?
                            <a href="{{ unsubscribeUrl|default('#') }}">Cliquez ici.</a>
                        </p>
                    </td>
                </tr>

            </table>
        </td>
    </tr>
</table>
</body>
</html>
{% endapply %}