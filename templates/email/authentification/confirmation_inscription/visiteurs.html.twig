{% apply inline_css(source('email/authentification/confirmation_inscription/visiteurs.css')) %}
    <!DOCTYPE html>
    <html lang="{{ app.request.locale|default('fr') }}">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{{ 'email.visiteur.register_confirmation.meta.title'|trans }}</title>
    </head>
    <body>
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="mail-wrapper">
        <tr>
            <td align="center">
                <table role="presentation" width="600" cellpadding="0" cellspacing="0" border="0" class="mail-container">

                    <tr>
                        <td class="mail-header">
                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" class="brand-table">
                                <tr>
                                    <td valign="middle">
                                        <img
                                            src="{{ absolute_url(asset('images/logo/mail.svg')) }}"
                                            alt="Boolts"
                                            class="brand-logo"
                                            width="134"
                                        >
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>

                    <tr>
                        <td class="mail-main">
                            <h1 class="mail-title">
                                {{ 'email.visiteur.register_confirmation.title'|trans({
                                    '%site%': 'boolts.com'
                                })|raw }}
                            </h1>

                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" class="button-wrapper">
                                <tr>
                                    <td>
                                        <a href="{{ url('app_visiteur_dashboard') }}" class="primary-button">
                                            {{ 'email.visiteur.register_confirmation.cta'|trans }}
                                        </a>
                                    </td>
                                </tr>
                            </table>

                            <p class="intro-text">
                                {{ 'email.visiteur.register_confirmation.intro'|trans }}
                            </p>
                        </td>
                    </tr>

                    <tr>
                        <td class="footer-top">
                            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                                <tr>
                                    <td class="footer-column" valign="top">
                                        <p class="footer-brand">boolts</p>
                                        <div class="footer-address">
                                            <p>©{{ "now"|date("Y") }} Boolts</p>
                                        </div>
                                    </td>

                                    <td class="footer-column-right" valign="top">
                                        <div class="social-icons">
                                            <a href="{{ instagramUrl|default('#') }}">
                                                <img src="{{ absolute_url(asset('images/logo/instagram.svg')) }}" alt="Instagram" width="20" height="20">
                                            </a>
                                            <a href="{{ facebookUrl|default('#') }}">
                                                <img src="{{ absolute_url(asset('images/logo/facebook.svg')) }}" alt="Facebook" width="20" height="20">
                                            </a>
                                        </div>

                                        <div class="footer-links">
                                            <p>
                                                <a href="{{ cguUrl|default('#') }}" target="_blank" rel="noopener">
                                                    {{ 'email.visiteur.register_confirmation.cgu'|trans }}
                                                </a>
                                            </p>
                                            <p>
                                                <a href="{{ contactUrl|default('#') }}" target="_blank" rel="noopener">
                                                    {{ 'email.visiteur.register_confirmation.contact'|trans }}
                                                </a>
                                            </p>
                                        </div>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>

                    <tr>
                        <td class="footer-legal">
                            <p>
                                {{ 'email.visiteur.register_confirmation.legal'|trans }}
                                <br>
                                {{ 'email.visiteur.register_confirmation.received'|trans({
                                    '%date%': "now"|date("d/m/Y")
                                }) }}
                            </p>
                            <p>
                                {{ 'email.visiteur.register_confirmation.unsubscribe_text'|trans }}
                                <a href="{{ unsubscribeUrl|default('#') }}">
                                    {{ 'email.visiteur.register_confirmation.unsubscribe_link'|trans }}
                                </a>
                            </p>
                        </td>
                    </tr>

                </table>
            </td>
        </tr>
    </table>
    </body>
    </html>
{% endapply %}
