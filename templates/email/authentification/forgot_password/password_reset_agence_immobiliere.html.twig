{% apply inline_css(source('email/authentification/forgot_password/password_reset.css')) %}
<!DOCTYPE html>
<html lang="{{ app.request.locale|default('fr') }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Modification du mot de passe</title>
</head>
<body>
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="mail-wrapper">
    <tr>
        <td align="center">
            <table role="presentation" width="600" cellpadding="0" cellspacing="0" border="0" class="mail-container">

                {# HEADER #} 
                <tr>
                    <td class="mail-header">
                        <table role="presentation" cellpadding="0" cellspacing="0" border="0" class="brand-table">
                            <tr>
                                <td valign="middle">
                                    {# Mets ici ton logo email en public ou en CID #}
                                    <img
                                        src="{{ absolute_url(asset('images/logo/mail.svg')) }}"
                                        alt="Boolts"
                                        class="brand-logo"
                                        width="134"
                                    >
                                </td>
                            </tr>
                        </table>
                    </td>
                </tr>

                {# MAIN CONTENT #}
                <tr>
                    <td class="mail-main">
                        <h1 class="mail-title">
                            Bonjour, voici le lien pour modifier votre mot de passe
                        </h1>

                        <table role="presentation" cellpadding="0" cellspacing="0" border="0" class="button-wrapper">
                            <tr>
                                <td>
                                    <a href="{{ url('agence_immobilierereset_password', {token: resetToken.token}) }}" class="primary-button">
                                        Modifier mon mot de passe
                                    </a>
                                </td>
                            </tr>
                        </table>

                        <p class="validity-text">
                            Prenez en compte que ce lien n’est valable que jusqu’au
                            {{ resetToken.expirationMessageKey|trans(resetToken.expirationMessageData, 'ResetPasswordBundle') }}
                        </p>

                        <div class="support-block">
                            <p>
                                Vous avez des soucis pour vous connecter ?<br>
                                Contactez notre support :
                                <a href="mailto:contact@boolts.com">contact@boolts.com</a>
                            </p>
                        </div>
                    </td>
                </tr>

                {# FOOTER TOP #}
                <tr>
                    <td class="footer-top">
                        <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                            <tr>
                                <td class="footer-column" valign="top">
                                    <p class="footer-brand">boolts</p>
                                    <div class="footer-address">
                                        <p>©{{ "now"|date("Y") }} Boolts</p>
                                    </div>
                                </td>

                                <td class="footer-column-right" valign="top">
                                    <div class="social-icons">
                                        <a href="{{ instagramUrl|default('#') }}" target="_blank">
                                            <img src="{{ absolute_url(asset('images/logo/instagram.svg')) }}" alt="Instagram">
                                        </a>
                                        <a href="{{ facebookUrl|default('#') }}" target="_blank">
                                            <img src="{{ absolute_url(asset('images/logo/facebook.svg')) }}" alt="Facebook">
                                        </a>
                                    </div>

                                    <div class="footer-links">
                                        <p>
                                            <a href="{{ cguUrl|default('#') }}" target="_blank">CGU</a>
                                        </p>
                                        <p>
                                            <a href="{{ contactUrl|default('#') }}" target="_blank">Nous contacter</a>
                                        </p>
                                    </div>
                                </td>
                            </tr>
                        </table>
                    </td>
                </tr>

                {# FOOTER LEGAL #}
                <tr>
                    <td class="footer-legal">
                        <p>
                            Boolts is a registered trademark. Instagram and Facebook are trademarks of Meta Inc., registered in the U.S. and other countries.
                            <br>
                            Vous avez reçu ce message parce que vous vous êtes inscrit sur notre site le 10 janvier 2024.
                        </p>
                        <p>
                            Vous ne souhaitez plus recevoir d’e-mail de notre part ?
                            <a href="{{ unsubscribeUrl|default('#') }}">Cliquez ici.</a>
                        </p>
                    </td>
                </tr>

            </table>
        </td>
    </tr>
</table>
</body>
</html>
{% endapply %}