{% apply inline_css(source('email/authentification/forgot_password/password_reset.css')) %}
    <!DOCTYPE html>
    <html lang="{{ app.request.locale|default('fr') }}">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{{ 'email.password_reset.meta.title'|trans }}</title>
    </head>
    <body>
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" class="mail-wrapper">
        <tr>
            <td align="center">
                <table role="presentation" width="600" cellpadding="0" cellspacing="0" border="0" class="mail-container">
                    <tr>
                        <td class="mail-header">
                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" class="brand-table">
                                <tr>
                                    <td valign="middle">
                                        <img src="{{ absolute_url(asset('images/logo/mail.svg')) }}" alt="Boolts" class="brand-logo" width="134">
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>

                    <tr>
                        <td class="mail-main">
                            <h1 class="mail-title">
                                {{ 'email.password_reset.title'|trans }}
                            </h1>

                            <table role="presentation" cellpadding="0" cellspacing="0" border="0" class="button-wrapper">
                                <tr>
                                    <td>
                                        <a href="{{ url('app_reset_password', {token: resetToken.token}) }}" class="primary-button">
                                            {{ 'email.password_reset.cta'|trans }}
                                        </a>
                                    </td>
                                </tr>
                            </table>

                            <p class="validity-text">
                                {{ 'email.password_reset.validity'|trans({
                                    '%expiration%': resetToken.expirationMessageKey|trans(resetToken.expirationMessageData, 'ResetPasswordBundle')
                                }) }}
                            </p>

                            <div class="support-block">
                                <p>
                                    {{ 'email.password_reset.support.text'|trans }}<br>
                                    {{ 'email.password_reset.support.contact'|trans }}
                                    <a href="mailto:contact@boolts.com">contact@boolts.com</a>
                                </p>
                            </div>
                        </td>
                    </tr>

                    <tr>
                        <td class="footer-top">
                            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                                <tr>
                                    <td class="footer-column" valign="top">
                                        <p class="footer-brand">boolts</p>
                                        <div class="footer-address">
                                            <p>©{{ "now"|date("Y") }} Boolts</p>
                                        </div>
                                    </td>

                                    <td class="footer-column-right" valign="top">
                                        <div class="social-icons">
                                            <a href="{{ instagramUrl|default('#') }}" target="_blank">
                                                <img src="{{ absolute_url(asset('images/logo/instagram.svg')) }}" alt="Instagram">
                                            </a>
                                            <a href="{{ facebookUrl|default('#') }}" target="_blank">
                                                <img src="{{ absolute_url(asset('images/logo/facebook.svg')) }}" alt="Facebook">
                                            </a>
                                        </div>

                                        <div class="footer-links">
                                            <p>
                                                <a href="{{ cguUrl|default('#') }}" target="_blank">
                                                    {{ 'email.password_reset.cgu'|trans }}
                                                </a>
                                            </p>
                                            <p>
                                                <a href="{{ contactUrl|default('#') }}" target="_blank">
                                                    {{ 'email.password_reset.contact'|trans }}
                                                </a>
                                            </p>
                                        </div>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>

                    <tr>
                        <td class="footer-legal">
                            <p>
                                {{ 'email.password_reset.legal'|trans }}
                                <br>
                                {{ 'email.password_reset.received'|trans({
                                    '%date%': "now"|date("d/m/Y")
                                }) }}
                            </p>
                            <p>
                                {{ 'email.password_reset.unsubscribe_text'|trans }}
                                <a href="{{ unsubscribeUrl|default('#') }}">
                                    {{ 'email.password_reset.unsubscribe_link'|trans }}
                                </a>
                            </p>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
    </body>
    </html>
{% endapply %}
